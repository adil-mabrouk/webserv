server {
    listen 0.0.0.0:7070;
    listen 127.0.0.1:9999;

    client_max_body_size 4;

    error_page 404 400 /errors/404.html;
    error_page 500 /;

	root	/home/amabrouk/webserv;

    location / {
        root /var/www/;
        index Makefile index.html index.htm;
        methods GET POST;
        autoindex on;
        allow_upload on;
        upload_store /www/uploads;
    }

    location /cgi-bin {
        root /var/www;
        methods GET POST;
        cgi_extension .php /usr/bin/php-cgi;
        cgi_extension .py /usr/bin/python3;
    }

    location /upload {
        root /upload;
        methods POST DELETE;
        upload_store /upload;
    }
    
    location /files {
        root /Request;
        methods GET;
        autoindex on;
    }

    location /redirect-me {
        return 301 /;
    }
}

